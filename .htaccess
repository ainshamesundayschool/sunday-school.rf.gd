RewriteEngine On

# ── InfinityFree / iFastNet cookie-check compatibility ──────────
# The host appends ?i=<number> after its cookie verification redirect.
# We must NOT strip or redirect that parameter server-side — doing so
# breaks the cookie-check flow and shows "Cookies are not enabled".
# Instead, we clean it client-side with JavaScript (see below) so the
# host can complete its verification first.

# Let the host serve the homepage directly.
DirectoryIndex index.html index.php

<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
</IfModule>

# CACHE CONTROL HEADERS - Simplified version
<IfModule mod_headers.c>
    <FilesMatch "^(manifest\.json|manifest\.webmanifest)$">
        Header set Content-Type "application/manifest+json"
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>

    # Disable caching for HTML, PHP files and the service worker
    <FilesMatch "\.(html|htm|php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Service worker must NEVER be cached — browser must always get the latest version
    <FilesMatch "^sw\.js$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
        Header set Service-Worker-Allowed "/"
    </FilesMatch>
</IfModule>

# Skip trailing-slash removal when the host's cookie-check param is present
RewriteCond %{QUERY_STRING} ^i=\d+$ [NC]
RewriteRule ^ - [L]

# Remove trailing slashes (only for non-directories, and only when NOT
# in the middle of the host cookie-check flow)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Allow access to existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Redirect to homepage if root is accessed
RewriteRule ^$ /index.html [L]

# Redirect /user to the actual directory entry point
RewriteRule ^user/?$ /user/index.html [L,QSA]

# Redirect /login to the actual directory entry point
RewriteRule ^login/?$ /login/index.html [L,QSA]

# Handle /uncle/dashboard
RewriteRule ^uncle/dashboard/?$ /uncle/dashboard/index.php [L,QSA]

# Fix 4: This line seems problematic - it redirects dashboard to dev
# Consider removing or fixing this duplicate rule
# RewriteRule ^uncle/dashboard/?$ /uncle/dev/ [L]

# Handle API calls
RewriteRule ^api/(.*)$ /api.php?request=$1 [L,QSA]

# Fix 5: Better API handling with query string preservation
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^api/(.*)$ /api.php?request=$1 [L,QSA]

# Redirect all other requests to api.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /api.php [L,QSA]
